# apps/api environment variables
# Copy to apps/api/.env for local dev — never commit real values.

NODE_ENV=development
PORT=4000

# Postgres connection (see SCHEMA.md). Used by `npm run db:migrate` / `npm run db:seed`.
DATABASE_URL=postgres://user:password@localhost:5432/pulse_v2

# Shared auth mechanism with Pathwisse (exact shape TBD — see ARCHITECTURE.md).
# Placeholder only; not wired up until T1.1.
PATHWISSE_AUTH_SHARED_SECRET=

# GitHub server-side token for public repo fetches (T1.3). Not wired up yet.
GITHUB_API_TOKEN=
