# apps/api environment variables
# Copy to apps/api/.env for local dev — never commit real values.

NODE_ENV=development
PORT=4000

# Postgres connection (see SCHEMA.md). Used by `npm run db:migrate` / `npm run db:seed`.
DATABASE_URL=postgres://user:password@localhost:5432/pulse_v2

# Shared auth mechanism with Pathwisse — token federation, see docs/decisions/001-auth.md.
# HMAC secret shared out-of-band with Pathwisse; verifies the handoff token they issue.
PATHWISSE_AUTH_SHARED_SECRET=

# Secret used to sign Pulse's own session cookie, issued after a handoff token is verified.
SESSION_COOKIE_SECRET=

# GitHub server-side token for public repo fetches (T1.3). Used for all users' repo
# lookups — not per-user OAuth. Needs no scopes beyond public repo read access.
GITHUB_API_TOKEN=
