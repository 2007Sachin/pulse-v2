# apps/web environment variables
# Copy to apps/web/.env.local for local dev — never commit real values.

# Base URL of the api service, used for server-side and client-side requests.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Shared auth mechanism with Pathwisse (exact shape TBD — see ARCHITECTURE.md).
# Placeholder only; not wired up until T1.1.
NEXT_PUBLIC_AUTH_DOMAIN=

# Server-only secret for the /admin/sync-events debug view (T4.4). Must match
# apps/api's ADMIN_DEBUG_SHARED_SECRET. Also doubles as the page's `?token=`
# access gate — never exposed to the client bundle (no NEXT_PUBLIC_ prefix).
ADMIN_DEBUG_SHARED_SECRET=
